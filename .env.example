# Frontend runtime labels
VITE_APP_VERSION=local

# Telemetry sampling rate between 0 and 1
VITE_WEB_VITALS_SAMPLE_RATE=1

# Optional API base URL.
# Examples:
# - /api (default, same-origin via reverse proxy)
# - https://api.example.com/v1 (cross-origin API gateway)
VITE_API_BASE_URL=/api

# Optional explicit Web Vitals endpoint.
# If unset, the app uses `${VITE_API_BASE_URL}/web-vitals`.
# VITE_WEB_VITALS_ENDPOINT=/api/web-vitals
